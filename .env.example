# Claude Gateway configuration example
# Copy this to .env or run: claude-gateway setup

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed chat IDs (comma-separated)
# Send a message to the bot to get your chat ID
ALLOWED_CHAT_IDS=123456789

# Default project directory (used for new sessions)
DEFAULT_PROJECT_PATH=/home/youruser/projects

# Directories to search when using /project <name> (comma-separated)
PROJECT_SEARCH_DIRS=/home/youruser/projects

# Directory where /newproject creates new folders
NEW_PROJECT_DIR=/home/youruser/projects

# Dashboard settings (optional, work in progress)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000
